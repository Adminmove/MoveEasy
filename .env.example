# ============================================================
# MoveEasy Environment Configuration
# Copy to .env and fill in all values before running
# NEVER commit .env to version control
# ============================================================

# --- App ---
NODE_ENV=development
PORT=4000
APP_SECRET=your_64_char_random_secret_here
CORS_ORIGIN=http://localhost:3000

# --- PostgreSQL (AWS RDS af-south-1) ---
DATABASE_URL=postgresql://moveeasy_user:password@localhost:5432/moveeasy_db
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000

# --- Redis (BullMQ job queues) ---
REDIS_URL=redis://localhost:6379

# --- Supabase (Auth + Realtime) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- PayFast (MoveEasy merchant account) ---
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_payfast_passphrase
PAYFAST_SANDBOX=true
PAYFAST_NOTIFY_URL=https://api.moveeasy.co.za/webhooks/payfast

# --- Purple Owl Payments (Softy Comp) ---
# Agreement signed 20 Aug 2025
PURPLE_OWL_MERCHANT_ID=your_pop_merchant_id
PURPLE_OWL_API_KEY=your_pop_api_key
PURPLE_OWL_BASE_URL=https://eft.softycomp.co.za/api
PURPLE_OWL_3DS_ENABLED=true

# --- Nedbank Nedlink ---
# Agreement signed 20 Aug 2025 — Reg: 2025/104466/07
NEDBANK_MERCHANT_NUMBER=your_merchant_number
NEDBANK_API_KEY=your_nedbank_api_key
NEDBANK_BASE_URL=https://api.nedbank.co.za
NEDBANK_AMEX_ENABLED=true
NEDBANK_MANUAL_ENTRY_ENABLED=true

# --- Ozow (Instant EFT for SafeBet) ---
OZOW_SITE_CODE=your_ozow_site_code
OZOW_PRIVATE_KEY=your_ozow_private_key
OZOW_API_KEY=your_ozow_api_key

# --- VALR (ZAR→USDC trading for SafeBet) ---
VALR_API_KEY=your_valr_api_key
VALR_API_SECRET=your_valr_api_secret
VALR_BASE_URL=https://api.valr.com

# --- Smile ID (KYC/Biometric — FICA compliant) ---
SMILE_ID_PARTNER_ID=your_partner_id
SMILE_ID_API_KEY=your_smile_id_api_key
SMILE_ID_BASE_URL=https://api.smileidentity.com/v1
SMILE_ID_CALLBACK_URL=https://api.moveeasy.co.za/webhooks/kyc

# --- Clickatell (SMS OTP) ---
CLICKATELL_API_KEY=your_clickatell_key
SMS_FROM=MoveEasy

# --- TransUnion (FuelFlex credit checks) ---
TRANSUNION_API_KEY=your_transunion_key
TRANSUNION_BASE_URL=https://api.transunion.co.za

# --- Anthropic Claude (AI Orchestrator) ---
ANTHROPIC_API_KEY=your_anthropic_key
AI_MODEL=claude-sonnet-4-20250514

# --- AWS ---
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=moveeasy-documents

# --- Fuel Price API ---
FUEL_PRICE_API_KEY=your_key
FUEL_PRICE_BASE_URL=https://api.fuel-prices-sa.co.za

# --- Security ---
JWT_SECRET=your_jwt_secret_min_64_chars
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=30d
VOUCHER_SECRET=your_voucher_hmac_secret_min_32_chars
ENCRYPTION_KEY=your_aes_256_key_32_bytes_hex

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
